# ───────────────────────────────────────────────────────
# Reading Assist – AWS Deployment Configuration
# ───────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# The deploy scripts (.deploy.ps1 / deploy.sh) will
# automatically load .env and export these variables.
# ───────────────────────────────────────────────────────

# ── AWS Credentials ────────────────────────────────────
# Either use access keys (recommended for personal use):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Or use an AWS CLI profile name (if you prefer aws configure):
# AWS_PROFILE=

# ── AWS Region ─────────────────────────────────────────
# CloudFront requires us-east-1 for SSL certificates,
# but other resources can be in your preferred region.
AWS_REGION=us-east-1

# ── Custom Domain (optional) ───────────────────────────
# Only needed if you want a custom domain like
# "reading.example.com" instead of the default
# CloudFront URL (dxxxxxxxxxxxx.cloudfront.net).
# Requires a Route 53 hosted zone for the apex domain.
# DOMAIN=reading.example.com
# HOSTED_ZONE_ID=Z1234567890
